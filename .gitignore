# Common .gitignore for Django Backend and React Frontend

# --- Dependencies ---
node_modules/
dist/
build/
venv/
env/
.env
.env.local
.env.*.local

# --- Python / Django ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
db.sqlite3
.pytest_cache/
.tox/
.coverage
htmlcov/

# --- React / Vite / JS ---
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# --- IDEs / Editors ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
Thumbs.db
ehthumbs.db
desktop.ini
